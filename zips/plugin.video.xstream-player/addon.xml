<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.xstream-player" name="XStream Player" version="2.1.4" provider-name="XStream Player">
    <requires>
        <import addon="xbmc.python" version="3.0.1"/>
        <import addon="script.module.requests" version="2.22.0"/>
        <import addon="pvr.iptvsimple" version="21.4.0"/>
        <import addon="service.upnext" version="1.1.0" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="resources/lib/addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">XStream Player - Organised M3U &amp; Xtream player</summary>
        <description lang="en_GB">A clean M3U &amp; Xtream player with proper sorting: PVR, Live TV, Movies, Series and Replay, plus EPG support.</description>
        <platform>all</platform>
        <license>MIT</license>
        <source>https://github.com/Pesicp/XStream-Player</source>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
